# ========================================
# SEOPilot - Environnement PRODUCTION
# ========================================
# Copiez ce fichier vers .env sur le VPS et configurez toutes les valeurs.
# NE COMMITEZ JAMAIS le fichier .env reel !

# Database (geree par Docker Compose, ne pas modifier le host)
DATABASE_URL="postgresql://seopilot:VOTRE_MOT_DE_PASSE_DB@seopilot-postgres:5432/seopilot"
DB_PASSWORD="VOTRE_MOT_DE_PASSE_DB"

# NextAuth (OBLIGATOIRE - changez ces valeurs !)
NEXTAUTH_URL="https://votre-domaine.com"
NEXTAUTH_SECRET="GENEREZ_AVEC_openssl_rand_-base64_32"

# AI Provider (au moins une cle requise)
OPENROUTER_API_KEY="sk-or-votre-cle-openrouter"
# OPENAI_API_KEY="sk-votre-cle-openai"

# Redis (geree par Docker Compose, ne pas modifier)
REDIS_URL="redis://seopilot-redis:6379"

# SMTP (pour les notifications email)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="votre-user-smtp"
SMTP_PASS="votre-password-smtp"
SMTP_FROM="noreply@seopilot.fr"

# Unsplash API
UNSPLASH_ACCESS_KEY="votre-cle-unsplash"

# App
NEXT_PUBLIC_APP_NAME="SEOPilot"
NEXT_PUBLIC_APP_URL="https://votre-domaine.com"

# Docker / Deploiement
DOMAIN="votre-domaine.com"
EMAIL="votre-email@example.com"
