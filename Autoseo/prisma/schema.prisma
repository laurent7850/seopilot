// --------------------------------------------------------------------------
// Prisma Schema - AutoSEO Platform
// --------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------------------------
// Enums
// --------------------------------------------------------------------------

enum Plan {
  FREE
  STARTER
  BUSINESS
  AGENCY
}

enum ArticleStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum BacklinkStatus {
  PENDING
  ACTIVE
  LOST
}

// --------------------------------------------------------------------------
// Auth Models (NextAuth)
// --------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// --------------------------------------------------------------------------
// User
// --------------------------------------------------------------------------

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  hashedPassword   String?
  image            String?
  emailVerified    DateTime?
  plan             Plan      @default(FREE)
  notifyArticle    Boolean   @default(true)
  notifyBacklink   Boolean   @default(true)
  notifyWeekly     Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  sites         Site[]
  notifications Notification[]
  progress      UserProgress[]

  @@index([email])
}

// --------------------------------------------------------------------------
// Notification
// --------------------------------------------------------------------------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // article_generated, backlink_lost, backlink_found, weekly_report
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

// --------------------------------------------------------------------------
// Site
// --------------------------------------------------------------------------

model Site {
  id              String   @id @default(cuid())
  userId          String
  url             String
  name            String
  niche           String?
  language        String   @default("en")
  market          String   @default("US")
  wordpressUrl    String?
  wordpressApiKey String?
  webhookUrl      String?
  webhookSecret   String?
  gscPropertyUrl  String?  // Google Search Console property URL
  gscAccessToken  String?  @db.Text
  gscRefreshToken String?  @db.Text
  ga4PropertyId   String?          // GA4 property ID (ex: "properties/123456789")
  ga4AccessToken  String?  @db.Text
  ga4RefreshToken String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  articles           Article[]
  keywords           Keyword[]
  backlinks          Backlink[]
  analyticsSnapshots AnalyticsSnapshot[]
  audits             SiteAudit[]
  crawlSessions      CrawlSession[]

  @@unique([userId, url])
  @@index([userId])
  @@index([isActive])
}

// --------------------------------------------------------------------------
// Article
// --------------------------------------------------------------------------

model Article {
  id              String        @id @default(cuid())
  siteId          String
  title           String
  slug            String
  content         String?       @db.Text
  metaTitle       String?
  metaDescription String?
  status          ArticleStatus @default(DRAFT)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  wordpressPostId String?
  wordCount       Int           @default(0)
  seoScore        Float?
  featuredImage   String?
  createdAt       DateTime      @default(now())

  site            Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  articleKeywords ArticleKeyword[]

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([status])
  @@index([scheduledAt])
  @@index([publishedAt])
}

// --------------------------------------------------------------------------
// Keyword
// --------------------------------------------------------------------------

model Keyword {
  id               String   @id @default(cuid())
  siteId           String
  term             String
  volume           Int?
  difficulty       Float?
  currentPosition  Float?
  previousPosition Float?
  trend            String?
  clicks           Int?
  impressions      Int?
  ctr              Float?
  lastSyncedAt     DateTime?
  createdAt        DateTime @default(now())

  site            Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  articleKeywords ArticleKeyword[]
  history         KeywordHistory[]

  @@unique([siteId, term])
  @@index([siteId])
  @@index([volume])
  @@index([currentPosition])
}

// --------------------------------------------------------------------------
// KeywordHistory (position tracking over time)
// --------------------------------------------------------------------------

model KeywordHistory {
  id        String   @id @default(cuid())
  keywordId String
  position  Float
  date      DateTime @default(now())

  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([keywordId, date])
  @@index([keywordId])
  @@index([date])
}

// --------------------------------------------------------------------------
// ArticleKeyword (many-to-many junction)
// --------------------------------------------------------------------------

model ArticleKeyword {
  id        String @id @default(cuid())
  articleId String
  keywordId String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([articleId, keywordId])
  @@index([articleId])
  @@index([keywordId])
}

// --------------------------------------------------------------------------
// Backlink
// --------------------------------------------------------------------------

model Backlink {
  id              String         @id @default(cuid())
  siteId          String
  sourceUrl       String
  targetUrl       String
  anchorText      String?
  status          BacklinkStatus @default(PENDING)
  domainAuthority Float?
  lastChecked     DateTime?
  createdAt       DateTime       @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, sourceUrl, targetUrl])
  @@index([siteId])
  @@index([status])
}

// --------------------------------------------------------------------------
// AnalyticsSnapshot
// --------------------------------------------------------------------------

model AnalyticsSnapshot {
  id                String   @id @default(cuid())
  siteId            String
  date              DateTime
  organicTraffic    Int      @default(0)
  totalKeywords     Int      @default(0)
  avgPosition       Float?
  backlinksCount    Int      @default(0)
  articlesPublished Int      @default(0)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date])
  @@index([siteId])
  @@index([date])
  @@index([siteId, date])
}

// --------------------------------------------------------------------------
// SiteAudit (technical SEO audit results)
// --------------------------------------------------------------------------

model SiteAudit {
  id            String   @id @default(cuid())
  siteId        String
  score         Int      // 0-100
  checks        Json     // AuditCheck[] serialized
  coreWebVitals Json?    // { lcp, cls, fcp, performanceScore, seoScore }
  createdAt     DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
}

// --------------------------------------------------------------------------
// CrawlSession (multi-page site crawl)
// --------------------------------------------------------------------------

enum CrawlStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model CrawlSession {
  id            String      @id @default(cuid())
  siteId        String
  status        CrawlStatus @default(PENDING)
  pagesFound    Int         @default(0)
  pagesCrawled  Int         @default(0)
  maxPages      Int         @default(50)
  issuesCount   Int         @default(0)
  score         Int?        // 0-100 global crawl score
  errorMessage  String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime    @default(now())

  site  Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pages CrawlPage[]

  @@index([siteId, createdAt])
  @@index([status])
}

// --------------------------------------------------------------------------
// CrawlPage (per-page SEO data from crawl)
// --------------------------------------------------------------------------

model CrawlPage {
  id              String   @id @default(cuid())
  crawlSessionId  String
  url             String
  statusCode      Int?
  title           String?
  metaDescription String?
  h1              String?
  h1Count         Int      @default(0)
  h2Count         Int      @default(0)
  wordCount       Int      @default(0)
  imagesTotal     Int      @default(0)
  imagesWithAlt   Int      @default(0)
  internalLinks   Int      @default(0)
  externalLinks   Int      @default(0)
  hasCanonical    Boolean  @default(false)
  canonicalUrl    String?
  hasOgTags       Boolean  @default(false)
  hasJsonLd       Boolean  @default(false)
  loadTimeMs      Int?
  contentHash     String?  // for duplicate content detection
  issues          Json     // CrawlPageIssue[] serialized
  depth           Int      @default(0)
  createdAt       DateTime @default(now())

  crawlSession CrawlSession @relation(fields: [crawlSessionId], references: [id], onDelete: Cascade)

  @@unique([crawlSessionId, url])
  @@index([crawlSessionId])
  @@index([statusCode])
}

// --------------------------------------------------------------------------
// UserProgress (roadmap/guide progression)
// --------------------------------------------------------------------------

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  stepKey     String
  completed   Boolean   @default(false)
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stepKey])
  @@index([userId])
}
